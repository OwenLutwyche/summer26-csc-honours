"""Testing online code for Codon-ported Bio.motifs (weblogo etc)."""

import os
import sys
import unittest

# Add the code directory to the path so we can import our Codon modules
sys.path.insert(0, "../../code")

try:
    import requires_internet
    requires_internet.check()
except ImportError:
    print("Warning: requires_internet module not found, assuming internet is available")

# Import from our Codon-ported motifs package
from motifs import __init__ as motifs

# We need Bio.Seq from Python for sequence creation
from python import Bio.Seq as BioSeq
Seq = BioSeq.Seq


class TestMotifWeblogo(unittest.TestCase):
    """Tests Codon-ported Bio.motifs online code."""

    def check(self, seqs_as_strs, alpha):
        # Using Seq objects:
        m = motifs.create([Seq(s) for s in seqs_as_strs], alpha)
        m.weblogo(os.devnull)
        # Using strings:
        m = motifs.create(seqs_as_strs, alpha)
        m.weblogo(os.devnull)

    def test_dna(self):
        """Test Codon motifs.weblogo with a DNA sequence."""
        self.check(
            ["TACAA", "TACGC", "TACAC", "TACCC", "AACCC", "AATGC", "AATGC"], "GATCBDSW"
        )

    def test_rna(self):
        """Test Codon motifs.weblogo with an RNA sequence."""
        self.check(
            ["UACAA", "UACGC", "UACAC", "UACCC", "AACCC", "AAUGC", "AAUGC"], "GAUC"
        )

    def test_protein(self):
        """Test Codon motifs.weblogo with a protein sequence."""
        self.check(
            ["ACDEG", "AYCRN", "HYLID", "AYHEL", "ACDEH", "AYYRN", "HYIID"],
            "ACDEFGHIKLMNPQRSTVWYBXZJUO",
        )


if __name__ == "__main__":
    runner = unittest.TextTestRunner(verbosity=2)
    unittest.main(testRunner=runner)
